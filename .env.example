# =====================================================================
# Loaded by pydantic-settings. Required keys are validated at startup;
# missing required keys cause the app to refuse to boot.
# =====================================================================

# Provider selection: "gemini" | "openai" | "azure"
LLM_PROVIDER=gemini

# --- Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Azure OpenAI ---
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=

# --- Agent runtime ---
MAX_AGENT_STEPS=10
AGENT_TIMEOUT_SECONDS=60
LLM_REQUEST_TIMEOUT_SECONDS=30

# --- Safety ---
ENABLE_INJECTION_DETECTION=false
REQUIRE_APPROVAL_FOR_WRITES=false

# --- Observability ---
TRACE_STORE_MAX=100
LOG_LEVEL=INFO
LOG_JSON=true                  # set false for human-readable logs locally

# --- Caching ---
TOOL_CACHE_TTL_SECONDS=300
TOOL_CACHE_MAXSIZE=512

# --- Storage paths ---
KNOWLEDGE_DATA_PATH=./data/acme-knowledge.json
TASKS_DATA_PATH=./data/sample-tasks.json
CHROMA_PATH=./.chroma

# --- Optional: LangSmith production tracing ---
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=project-4-agents
